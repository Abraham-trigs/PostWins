{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "Bundler",

    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],

    "jsx": "preserve",
    "incremental": true,

    "strict": true,
    "noUncheckedIndexedAccess": true,

    "allowJs": true,
    "noEmit": true,
    "isolatedModules": true,
    "resolveJsonModule": true,

    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@ui/*": ["./src/app/postwins/_components/*"],
      "@postwin-store/*": ["./src/app/postwins/_components/chat/store/*"],
      "@posta/core": ["../../packages/core/src/index.ts"]
    },

    "plugins": [{ "name": "next" }]
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
